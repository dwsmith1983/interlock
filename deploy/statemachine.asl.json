{
  "Comment": "Interlock v2 pipeline lifecycle: evaluation, trigger, job polling, SLA monitoring via EventBridge Scheduler",
  "StartAt": "InitEvalLoop",
  "TimeoutSeconds": ${sfn_timeout_seconds},
  "States": {
    "InitEvalLoop": {
      "Type": "Pass",
      "Comment": "Initialize elapsed-seconds counter for the evaluation window",
      "Result": {
        "elapsedSeconds": 0
      },
      "ResultPath": "$.evalLoop",
      "Next": "Evaluate"
    },
    "Evaluate": {
      "Type": "Task",
      "Resource": "${orchestrator_arn}",
      "Parameters": {
        "mode": "evaluate",
        "pipelineId.$": "$.pipelineId",
        "scheduleId.$": "$.scheduleId",
        "date.$": "$.date"
      },
      "ResultPath": "$.evaluateResult",
      "Next": "IsReady",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.TooManyRequestsException",
            "States.TaskFailed"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.errorInfo",
          "Next": "InfraFailure"
        }
      ]
    },
    "IsReady": {
      "Type": "Choice",
      "Comment": "Check if all traits passed evaluation",
      "Choices": [
        {
          "Variable": "$.evaluateResult.status",
          "StringEquals": "passed",
          "Next": "Trigger"
        }
      ],
      "Default": "WaitInterval"
    },
    "WaitInterval": {
      "Type": "Wait",
      "Comment": "Wait before the next evaluation attempt",
      "SecondsPath": "$.config.evaluationIntervalSeconds",
      "Next": "IncrementElapsed"
    },
    "IncrementElapsed": {
      "Type": "Pass",
      "Comment": "Track total elapsed seconds in the evaluation window",
      "Parameters": {
        "elapsedSeconds.$": "States.MathAdd($.evalLoop.elapsedSeconds, $.config.evaluationIntervalSeconds)"
      },
      "ResultPath": "$.evalLoop",
      "Next": "CheckWindowExhausted"
    },
    "CheckWindowExhausted": {
      "Type": "Choice",
      "Comment": "Has the evaluation window been exceeded?",
      "Choices": [
        {
          "Variable": "$.evalLoop.elapsedSeconds",
          "NumericGreaterThanEqualsPath": "$.config.evaluationWindowSeconds",
          "Next": "ValidationExhausted"
        }
      ],
      "Default": "Evaluate"
    },
    "ValidationExhausted": {
      "Type": "Task",
      "Comment": "Publish VALIDATION_EXHAUSTED event; window closed without passing",
      "Resource": "${orchestrator_arn}",
      "Parameters": {
        "mode": "validation-exhausted",
        "pipelineId.$": "$.pipelineId",
        "scheduleId.$": "$.scheduleId",
        "date.$": "$.date"
      },
      "ResultPath": "$.validationExhaustedResult",
      "Next": "CheckCancelSLA",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.TooManyRequestsException",
            "States.TaskFailed"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.errorInfo",
          "Next": "InfraFailure"
        }
      ]
    },
    "Trigger": {
      "Type": "Task",
      "Comment": "Invoke the pipeline trigger; returns a runId and metadata. Infra failures return Lambda errors retried with exponential backoff (30s, 60s, 120s, 240s).",
      "Resource": "${orchestrator_arn}",
      "Parameters": {
        "mode": "trigger",
        "pipelineId.$": "$.pipelineId",
        "scheduleId.$": "$.scheduleId",
        "date.$": "$.date"
      },
      "ResultPath": "$.triggerResult",
      "Next": "HasTriggerResult",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.TooManyRequestsException",
            "States.TaskFailed"
          ],
          "IntervalSeconds": 30,
          "MaxAttempts": ${trigger_max_attempts},
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.errorInfo",
          "Next": "TriggerRetryExhausted"
        }
      ]
    },
    "TriggerRetryExhausted": {
      "Type": "Task",
      "Comment": "Publish RETRY_EXHAUSTED event, write joblog entry, release trigger lock",
      "Resource": "${orchestrator_arn}",
      "Parameters": {
        "mode": "trigger-exhausted",
        "pipelineId.$": "$.pipelineId",
        "scheduleId.$": "$.scheduleId",
        "date.$": "$.date",
        "errorInfo.$": "$.errorInfo"
      },
      "ResultPath": "$.triggerExhaustedResult",
      "Next": "CheckCancelSLA",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.TooManyRequestsException",
            "States.TaskFailed"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.errorInfo",
          "Next": "CheckCancelSLA"
        }
      ]
    },
    "HasTriggerResult": {
      "Type": "Choice",
      "Comment": "If a job was triggered, poll for completion; otherwise finish (validation exhausted)",
      "Choices": [
        {
          "Variable": "$.triggerResult",
          "IsPresent": true,
          "Next": "InitJobPollLoop"
        }
      ],
      "Default": "FailValidationExhausted"
    },
    "FailValidationExhausted": {
      "Type": "Fail",
      "Error": "ValidationExhausted",
      "Cause": "Evaluation window closed without all validation rules passing"
    },
    "InitJobPollLoop": {
      "Type": "Pass",
      "Comment": "Initialize elapsed-seconds counter for job poll window",
      "Result": { "elapsedSeconds": 0 },
      "ResultPath": "$.jobPollLoop",
      "Next": "WaitForJob"
    },
    "WaitForJob": {
      "Type": "Wait",
      "Comment": "Wait before polling the triggered job",
      "SecondsPath": "$.config.jobCheckIntervalSeconds",
      "Next": "CheckJob"
    },
    "CheckJob": {
      "Type": "Task",
      "Comment": "Poll triggered job status via trigger API",
      "Resource": "${orchestrator_arn}",
      "Parameters": {
        "mode": "check-job",
        "pipelineId.$": "$.pipelineId",
        "scheduleId.$": "$.scheduleId",
        "date.$": "$.date",
        "runId.$": "$.triggerResult.runId",
        "metadata.$": "$.triggerResult.metadata"
      },
      "ResultPath": "$.checkJobResult",
      "Next": "IsJobDone",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.TooManyRequestsException",
            "States.TaskFailed"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.errorInfo",
          "Next": "InfraFailure"
        }
      ]
    },
    "IsJobDone": {
      "Type": "Choice",
      "Comment": "Route on job-check outcome: terminal events proceed to trigger completion, otherwise keep polling",
      "Choices": [
        {
          "Not": {
            "Variable": "$.checkJobResult.event",
            "IsPresent": true
          },
          "Next": "IncrementJobPollElapsed"
        },
        {
          "Variable": "$.checkJobResult.event",
          "StringEquals": "success",
          "Next": "CheckHasPostRun"
        },
        {
          "Variable": "$.checkJobResult.event",
          "StringEquals": "fail",
          "Next": "CompleteTrigger"
        },
        {
          "Variable": "$.checkJobResult.event",
          "StringEquals": "timeout",
          "Next": "CompleteTrigger"
        }
      ],
      "Default": "IncrementJobPollElapsed"
    },
    "IncrementJobPollElapsed": {
      "Type": "Pass",
      "Comment": "Track total elapsed seconds in job poll window",
      "Parameters": {
        "elapsedSeconds.$": "States.MathAdd($.jobPollLoop.elapsedSeconds, $.config.jobCheckIntervalSeconds)"
      },
      "ResultPath": "$.jobPollLoop",
      "Next": "CheckJobPollExhausted"
    },
    "CheckJobPollExhausted": {
      "Type": "Choice",
      "Comment": "Has the job poll window been exceeded?",
      "Choices": [
        {
          "Variable": "$.jobPollLoop.elapsedSeconds",
          "NumericGreaterThanEqualsPath": "$.config.jobPollWindowSeconds",
          "Next": "JobPollExhausted"
        }
      ],
      "Default": "WaitForJob"
    },
    "JobPollExhausted": {
      "Type": "Task",
      "Comment": "Publish JOB_POLL_EXHAUSTED event and write timeout joblog",
      "Resource": "${orchestrator_arn}",
      "Parameters": {
        "mode": "job-poll-exhausted",
        "pipelineId.$": "$.pipelineId",
        "scheduleId.$": "$.scheduleId",
        "date.$": "$.date",
        "runId.$": "$.triggerResult.runId"
      },
      "ResultPath": "$.jobPollExhaustedResult",
      "Next": "InjectTimeoutEvent",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.TooManyRequestsException",
            "States.TaskFailed"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.errorInfo",
          "Next": "InjectTimeoutEvent"
        }
      ]
    },
    "InjectTimeoutEvent": {
      "Type": "Pass",
      "Comment": "Inject timeout event so CompleteTrigger reads event=timeout",
      "Result": { "event": "timeout" },
      "ResultPath": "$.checkJobResult",
      "Next": "CompleteTrigger"
    },
    "CheckHasPostRun": {
      "Type": "Choice",
      "Comment": "Route to post-run monitoring if postRun rules are configured",
      "Choices": [
        {
          "Variable": "$.config.hasPostRun",
          "BooleanEquals": true,
          "Next": "InitPostRunLoop"
        }
      ],
      "Default": "CompleteTrigger"
    },
    "InitPostRunLoop": {
      "Type": "Pass",
      "Comment": "Initialize elapsed-seconds counter for post-run monitoring window",
      "Result": { "elapsedSeconds": 0 },
      "ResultPath": "$.postRunLoop",
      "Next": "PostRunEvaluate"
    },
    "PostRunEvaluate": {
      "Type": "Task",
      "Comment": "Evaluate post-run validation rules (audit check)",
      "Resource": "${orchestrator_arn}",
      "Parameters": {
        "mode": "post-run",
        "pipelineId.$": "$.pipelineId",
        "scheduleId.$": "$.scheduleId",
        "date.$": "$.date"
      },
      "ResultPath": "$.postRunResult",
      "Next": "IsPostRunDone",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.TooManyRequestsException",
            "States.TaskFailed"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.errorInfo",
          "Next": "CompleteTrigger"
        }
      ]
    },
    "IsPostRunDone": {
      "Type": "Choice",
      "Comment": "Check if post-run detected drift or window expired",
      "Choices": [
        {
          "Variable": "$.postRunResult.status",
          "StringEquals": "drift",
          "Next": "CompleteTrigger"
        },
        {
          "Variable": "$.postRunLoop.elapsedSeconds",
          "NumericGreaterThanEqualsPath": "$.config.postRunWindowSeconds",
          "Next": "CompleteTrigger"
        }
      ],
      "Default": "WaitForPostRun"
    },
    "WaitForPostRun": {
      "Type": "Wait",
      "Comment": "Wait before next post-run check",
      "SecondsPath": "$.config.postRunIntervalSeconds",
      "Next": "IncrementPostRunElapsed"
    },
    "IncrementPostRunElapsed": {
      "Type": "Pass",
      "Comment": "Track total elapsed seconds in post-run window",
      "Parameters": {
        "elapsedSeconds.$": "States.MathAdd($.postRunLoop.elapsedSeconds, $.config.postRunIntervalSeconds)"
      },
      "ResultPath": "$.postRunLoop",
      "Next": "PostRunEvaluate"
    },
    "CompleteTrigger": {
      "Type": "Task",
      "Comment": "Set trigger row to terminal status: COMPLETED on success, FAILED_FINAL on fail/timeout",
      "Resource": "${orchestrator_arn}",
      "Parameters": {
        "mode": "complete-trigger",
        "pipelineId.$": "$.pipelineId",
        "scheduleId.$": "$.scheduleId",
        "date.$": "$.date",
        "event.$": "$.checkJobResult.event"
      },
      "ResultPath": "$.completeTriggerResult",
      "Next": "CheckCancelSLA",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.TooManyRequestsException",
            "States.TaskFailed"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.errorInfo",
          "Next": "CheckCancelSLA"
        }
      ]
    },
    "CheckCancelSLA": {
      "Type": "Choice",
      "Comment": "Cancel SLA schedules if SLA was configured, otherwise finish",
      "Choices": [
        {
          "Variable": "$.config.sla",
          "IsPresent": true,
          "Next": "CancelSLASchedules"
        }
      ],
      "Default": "Done"
    },
    "CancelSLASchedules": {
      "Type": "Task",
      "Comment": "Delete unfired SLA schedules and record final SLA outcome",
      "Resource": "${sla_monitor_arn}",
      "Parameters": {
        "mode": "cancel",
        "pipelineId.$": "$.pipelineId",
        "scheduleId.$": "$.scheduleId",
        "date.$": "$.date",
        "deadline.$": "$.config.sla.deadline",
        "expectedDuration.$": "$.config.sla.expectedDuration"
      },
      "ResultPath": "$.slaResult",
      "Next": "Done",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.AWSLambdaException",
            "Lambda.TooManyRequestsException",
            "States.TaskFailed"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "ResultPath": "$.errorInfo",
          "Next": "Done"
        }
      ]
    },
    "InfraFailure": {
      "Type": "Fail",
      "Error": "InfraFailure",
      "Cause": "Unrecoverable infrastructure error"
    },
    "Done": {
      "Type": "Succeed"
    }
  }
}
